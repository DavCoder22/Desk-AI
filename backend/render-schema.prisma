generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ticket {
  id                      String   @id @default(uuid())
  title                   String
  description             String
  category                String   @default("PENDIENTE")
  subcategoria            String?
  tipo_solicitud          String?
  priority                String   @default("medio")
  urgency                 String   @default("medio")
  impact                  String   @default("medio")
  status                  String   @default("PENDIENTE_CLASIFICACION")
  tipo_usuario            String   @default("ESTUDIANTE")
  facultad_o_area         String?
  carrera                 String?
  requester               String
  assigned_to             String?
  ai_suggestion           String?
  user_recommendation     String?
  supervisor_suggestion   String?
  itil_category           String?
  cobit_control           String?
  feedback_ia             Json?
  resolution_time_minutes Int?
  cost_human              Float?
  cost_ia                 Float?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt
  resolved_at             DateTime?

  audit_logs AuditLog[]
  feedbacks  IAFeedback[]
}

model AuditLog {
  id        String   @id @default(uuid())
  ticket_id String
  action    String
  details   Json?
  timestamp DateTime @default(now())

  ticket Ticket @relation(fields: [ticket_id], references: [id])
}

model IAFeedback {
  id                        String   @id @default(uuid())
  ticket_id                 String
  categoria_sugerida_por_ia String
  clasificacion_correcta    Boolean
  sugerencia_util           Boolean
  comentarios               String?
  created_at                DateTime @default(now())

  ticket Ticket @relation(fields: [ticket_id], references: [id])
}

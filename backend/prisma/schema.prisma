generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ticket {
  id                      String   @id @default(uuid()) @db.Uuid
  title                   String   @db.VarChar(255)
  description             String   @db.Text
  category                String   @db.VarChar(80)
  subcategoria            String?  @db.VarChar(120)
  tipo_solicitud          String?  @db.VarChar(30)
  priority                String   @default("medio") @db.VarChar(20)
  urgency                 String   @default("medio") @db.VarChar(20)
  impact                  String   @default("medio") @db.VarChar(20)
  status                  String   @default("PENDIENTE_CLASIFICACION") @db.VarChar(30)
  tipo_usuario            String   @default("ESTUDIANTE") @db.VarChar(20)
   facultad_o_area         String?  @db.VarChar(150)
   carrera                 String?  @db.VarChar(150)
   requester               String   @db.VarChar(150)
  assigned_to             String?  @db.VarChar(150)
  ai_suggestion           String?  @db.Text
   user_recommendation      String?  @db.Text
   supervisor_suggestion    String?  @db.Text
   itil_category            String?  @db.VarChar(50)
   cobit_control            String?  @db.VarChar(20)
   feedback_ia             Json?
  resolution_time_minutes Int?
  cost_human              Float?
  cost_ia                 Float?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt
  resolved_at             DateTime?

  audit_logs AuditLog[]
  feedbacks  IAFeedback[]
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  ticket_id String   @db.Uuid
  action    String   @db.VarChar(50)
  details   Json?
  timestamp DateTime @default(now())

  ticket Ticket @relation(fields: [ticket_id], references: [id])
}

model IAFeedback {
  id                        String   @id @default(uuid()) @db.Uuid
  ticket_id                 String   @db.Uuid
  categoria_sugerida_por_ia String   @db.VarChar(50)
  clasificacion_correcta    Boolean
  sugerencia_util           Boolean
  comentarios               String?  @db.Text
  created_at                DateTime @default(now())

  ticket Ticket @relation(fields: [ticket_id], references: [id])
}

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Compiled / generated output
dist/
build/
.next/
.nyc_output/

# Dependency directories
node_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# Stores VSCode versions used for testing
.vscode-test/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Temporary / lock files
*.tmp
*.lock
*.~lock.*

# Local SQLite database (regenerable)
backend/prisma/dev.db
backend/prisma/dev.db-journal

# Prisma generated client (regenerable con npm install / prisma generate)
backend/prisma/generated/
backend/generated/

# API keys - NUNCA subir
backend/ai-config.json

# Docs/screenshots are allowed (keep them tracked)

# Error logs
*.err

# Next.js generated
frontend/next-env.d.ts

# Screenshots (use docs/screenshots/ instead)
captura*.png

# Duplicate render schema (use backend/prisma/render-schema.prisma)
backend/render-schema.prisma

# Project leftovers
my-app/
